# Supabase — for reading OAuth tokens from hubspot_connections / salesforce_connections
SUPABASE_URL=https://rvyupvkuxghipscbggtj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# HubSpot — for token refresh (same values as in Supabase edge function secrets)
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret

# Stripe — secret API key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=your-stripe-secret-key

# Default organization ID (from integrale-app organizations table)
DEFAULT_ORG_ID=your-org-uuid

# Salesforce — OAuth credentials
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret

# SAP — API key for Business Accelerator Hub
SAP_API_KEY=your-sap-api-key

# Server port
PORT=3001

# Public URL (set to your Railway/Render domain in production)
# Used for OAuth callback redirect URIs
# PUBLIC_URL=https://your-app.up.railway.app
